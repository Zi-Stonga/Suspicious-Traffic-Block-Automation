# record_ip Lambda
DYNAMODB_TABLE=AutoBlockedIPs-dev
ENVIRONMENT=dev
BLOCK_TTL_HOURS=24

# block_traffic Lambda
RULE_GROUP_ARN=arn:aws:network-firewall:us-east-1:123456789012:stateless-rulegroup/auto-ip-blocker-dev-dynamic
RULE_GROUP_NAME=auto-ip-blocker-dev-dynamic
MAX_RULES=1000

# notify Lambda
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:auto-ip-blocker-dev-alerts

# shared
LOG_LEVEL=DEBUG
